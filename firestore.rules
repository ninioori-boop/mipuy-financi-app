rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    match /maps/{clientUid} {
      allow read, write: if request.auth != null && request.auth.uid == clientUid;
      allow read, write: if request.auth != null && request.auth.uid == resource.data.advisorUid;
    }
    match /invites/{code} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update: if request.auth != null && resource.data.used == false;
    }
  }
}
